flowchart TD
    subgraph S1 [Step 1: Get the Data]
        A1[Select a TON API] --> A2[Use jetton/transfers endpoint];
        A2 --> A3[Fetch all historical transfers];
    end

    subgraph S2 [Step 2: Structure the Data]
        B1[Parse API response];
        B1 --> B2[Create a nodes list for wallets];
        B1 --> B3[Create an edges list for transfers];
        B2 --> B4[JSON for Graph Library];
        B3 --> B4;
    end

    subgraph S3 [Step 3: Visualize the Network]
        C1[Choose graph library<br>Cytoscape.js or Sigma.js] --> C2[Build web page<br>Import JSON data];
        C2 --> C3[Configure & render graph];
    end

    S1 --> S2 --> S3